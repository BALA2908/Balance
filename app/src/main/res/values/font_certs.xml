<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificates for the Google Fonts downloadable-font provider (com.google.android.gms.fonts).
  These are the standard, public Google Play Services font certs used by every app that
  uses Compose downloadable fonts. If a font ever fails to download, the Compose
  GoogleFont() calls in Type.kt fall back to system fonts automatically (app still works).
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
