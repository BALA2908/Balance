<?xml version="1.0" encoding="utf-8"?>
<!-- Financial data is encrypted at rest and never backed up off-device. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
